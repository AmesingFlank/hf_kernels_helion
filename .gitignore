# Nix build symlinks into /nix/store get GC'd; we instead commit the
# reconstructed pure-Python noarch build/ dirs and relative `result` symlinks
# (see rebuild_noarch.py). So build/ and result are NOT ignored.

# Python caches
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/

# Nix
.direnv/

# transient run logs
*.log

# AOT tuning run artifacts (transient; only the _helion_aot_*.py heuristics beside kernels matter)
.helion_aot/
